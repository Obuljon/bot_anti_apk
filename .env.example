# .env.example — Copy this to .env and fill in your values

# Your bot token from @BotFather
BOT_TOKEN=8063000745:AAG1suoPu4BPPNVfr2-CNu-wf6we8siaMI4

# Optional: comma-separated list of admin user IDs (can override deletion)
# Example: ADMIN_IDS=123456789,987654321
